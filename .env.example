# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ngrok auth token from https://dashboard.ngrok.com
NGROK_TOKEN=your_ngrok_token_here

# LLM backend: "ollama" (default) or "openai"
LLM_BACKEND=ollama

# Ollama settings (used if LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4

# OpenAI settings (used if LLM_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
